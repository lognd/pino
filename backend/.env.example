DATABASE_URL=postgresql+asyncpg://melpino:changeme@localhost:5432/melpino
# Same password as DATABASE_URL's embedded one -- read separately by
# docker-compose.yml's postgres service (the official postgres image
# requires this env var to initialize a fresh data volume; DATABASE_URL
# alone is not enough since the app and the postgres container read two
# different env vars). Keep both in sync when rotating -- see
# docs/secrets.md.
POSTGRES_PASSWORD=changeme
REDIS_URL=
SESSION_SECRET=changeme-dev-only-insecure-secret
# Unset (blank) means Stripe is NOT configured -- GET /api/config reports
# stripe:false until this is a real sk_test_.../sk_live_... secret.
PAYMENT_PROCESSOR_SECRET=
STRIPE_WEBHOOK_SECRET=whsec_fake
STRIPE_API_BASE=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_API_BASE=
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
PUBLIC_BASE_URL=https://SITE-DOMAIN-TBD
BUSINESS_LEGAL_NAME=Mel Pino, LLC
BUSINESS_SHORT_NAME=Mel Pino
INVOICE_BUSINESS_DETAILS=
INVOICE_CONTACT_EMAIL=billing@SITE-DOMAIN-TBD
ZELLE_HANDLE=
BOOKING_CANCELLATION_HOURS=24
REMINDER_DAYS_BEFORE=2
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=changeme
SMTP_USE_TLS=true
SMTP_FROM_ADDRESS=noreply@SITE-DOMAIN-TBD
GMAIL_SERVICE_ACCOUNT_JSON=
GMAIL_SENDER_EMAIL=
GMAIL_TOKEN_API_BASE=
GMAIL_API_BASE=
MAILING_ADDRESS=
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=./data/storage
R2_BUCKET=
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=changeme
R2_PUBLIC_BASE_URL=
HOST=127.0.0.1
PORT=8000
