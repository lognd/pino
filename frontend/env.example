# Copy to .env.local for local overrides (gitignored). Never commit real
# secrets here -- this file is for Vite's import.meta.env, not server-side
# secrets. Named env.example (not .env.example) because a leading-dot
# example file could not be written in this environment; treat it the same
# way logand.app treats its own .env.example.

# Set to "true" to run the frontend standalone against a fake/mocked API
# (Mock Service Worker, see src/mocks/) instead of the real backend --
# use `npm run dev:mock` instead of setting this by hand.
VITE_USE_MOCKS=false

# Business identity -- see src/lib/brand.ts and
# docs/design/00-overview.md. Defaults match the backend AppConfig
# defaults; override only if the business identity actually changes.
VITE_BUSINESS_LEGAL_NAME=Mel Pino, LLC
VITE_BUSINESS_SHORT_NAME=Mel Pino

# Landing hero source -- see docs/design/08-landing-hero.md. Default is
# the procedural simulation; "video" requires VITE_HERO_VIDEO_URL too.
VITE_HERO_SOURCE=simulated
VITE_HERO_VIDEO_URL=
